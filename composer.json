{
    "name": "wabridge/wabridge",
    "description": "WhatsApp veli grubu export .txt -> yapilandirilmis haftalik digest (P0).",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "ext-mbstring": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "WABridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WABridge\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "php tests/run.php",
        "serve": "php -S localhost:8000 -t public"
    },
    "config": {
        "sort-packages": true
    }
}
