# WABridge ortam ayarları — GERÇEK SECRET'LARI BURAYA YAZMA.
# Bu dosya şablondur; kopyala: cp .env.example .env  ve .env'i doldur.
# .env .gitignore'dadır; secret koda/log'a/CLAUDE.md'ye ASLA yazılmaz.

# --- Runtime LLM (ürünün çıkarım katmanı; Claude Code build aracından AYRIDIR) ---
# Kademeli maliyet kuralı: bulk sınıflama ucuz modele, yapılandırma üst modele.
WABRIDGE_LLM_API_KEY=
WABRIDGE_LLM_BASE_URL=https://api.anthropic.com
WABRIDGE_CHEAP_MODEL=claude-haiku-4-5-20251001
WABRIDGE_UPPER_MODEL=claude-opus-4-8

# Hangi sınıflandırıcı kullanılsın: "heuristic" (deterministik, API'siz) | "llm"
# Testler her zaman heuristic yolu koşar; production "llm" olur.
WABRIDGE_CLASSIFIER=heuristic

# Web katmanı
WABRIDGE_MAX_UPLOAD_BYTES=10485760
WABRIDGE_CSRF_SECRET=
