# WABridge ortam ayarları — GERÇEK SECRET'LARI BURAYA YAZMA.
# Bu dosya şablondur; kopyala: cp .env.example .env  ve .env'i doldur.
# .env .gitignore'dadır; secret koda/log'a/CLAUDE.md'ye ASLA yazılmaz.

# --- Runtime LLM (ürünün çıkarım katmanı; Claude Code build aracından AYRIDIR) ---
# Kademeli maliyet kuralı: bulk sınıflama ucuz modele, yapılandırma üst modele.
WABRIDGE_LLM_API_KEY=
WABRIDGE_LLM_BASE_URL=https://api.anthropic.com
WABRIDGE_CHEAP_MODEL=claude-haiku-4-5-20251001
WABRIDGE_UPPER_MODEL=claude-opus-4-8

# Hangi sınıflandırıcı kullanılsın: "heuristic" (deterministik, API'siz) | "llm"
# Testler her zaman heuristic yolu koşar; production "llm" olur.
WABRIDGE_CLASSIFIER=heuristic

# Web katmanı
WABRIDGE_MAX_UPLOAD_BYTES=10485760
WABRIDGE_CSRF_SECRET=

# --- Kalıcılık (v1a) ---
# SQLite dosya yolu, proje köküne göre göreli (mutlak da olabilir).
# Sadece ÜRETİLMİŞ digest JSON'u + hesap/grup meta verisi tutar; ham export ASLA.
WABRIDGE_DB_PATH=storage/wabridge.sqlite

# --- E-posta / magic-link auth (v1a) ---
# "log" (dev/test — gerçek e-posta göndermez, storage/mail.log'a yazar) | "curl" (prod)
WABRIDGE_MAIL_DRIVER=log
WABRIDGE_MAIL_LOG_PATH=storage/mail.log
WABRIDGE_MAIL_API_KEY=
WABRIDGE_MAIL_API_URL=
WABRIDGE_MAIL_FROM=no-reply@wabridge.local
WABRIDGE_APP_BASE_URL=http://localhost:8000
WABRIDGE_MAGIC_LINK_TTL_MIN=20

# --- Ödeme (v1b — iyzico; şahıs şirketi ön koşulu için docs/PRODUCT_v1_DESIGN.md'ye bak) ---
WABRIDGE_IYZICO_API_KEY=
WABRIDGE_IYZICO_SECRET_KEY=
WABRIDGE_IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
WABRIDGE_FREE_DIGEST_LIMIT=4
